# ===========================================================================
# Projeto Dark - variaveis de ambiente
# Copie este arquivo para ".env" e preencha. O .env NUNCA vai pro git.
# ===========================================================================

# Porta do servidor local (3000 costuma estar ocupada por outros apps; usamos 4310)
PORT=4310

# URL base (use a mesma porta acima). Os "redirect URI" do OAuth apontam pra ca.
BASE_URL=http://localhost:4310

# Chave para cifrar os tokens das contas no banco (32+ caracteres aleatorios).
# Gere uma com:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=troque-isto-por-uma-chave-aleatoria-de-32-bytes

# Fuso horario usado nos agendamentos (horarios das campanhas)
TZ=America/Sao_Paulo

# ---------------------------------------------------------------------------
# LOGIN DOS USUARIOS (Supabase) — OPCIONAL.
# Se deixar VAZIO, o app roda em modo local (sem tela de login).
# Se preencher, o app passa a EXIGIR login (Google ou e-mail+senha).
# Onde achar: painel do Supabase -> Project Settings -> API.
#   SUPABASE_URL        = "Project URL"
#   SUPABASE_ANON_KEY   = "anon public" (pode ir pro cliente, e publica)
#   SUPABASE_JWT_SECRET = Project Settings -> API -> "JWT Secret" (NUNCA exponha)
# Passo a passo completo em SETUP-LOGIN.md.
# ---------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# ---------------------------------------------------------------------------
# YouTube (Google Cloud Console -> API "YouTube Data API v3" -> OAuth Client)
# Redirect URI: http://localhost:4310/oauth/youtube/callback
# ---------------------------------------------------------------------------
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Instagram + Facebook (Meta for Developers -> Facebook Login + Graph API)
# As MESMAS credenciais valem para Instagram E Facebook (mesmo app do Meta).
# Instagram: conta Profissional (Business/Creator) ligada a uma Pagina.
# Facebook: voce precisa administrar uma Pagina (o video e postado nela).
# Redirect URIs:
#   http://localhost:4310/oauth/instagram/callback
#   http://localhost:4310/oauth/facebook/callback
# ---------------------------------------------------------------------------
META_APP_ID=
META_APP_SECRET=

# ---------------------------------------------------------------------------
# TikTok (TikTok for Developers -> Login Kit + Content Posting API)
# Redirect URI: http://localhost:4310/oauth/tiktok/callback
# ---------------------------------------------------------------------------
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# (Facebook usa as credenciais META_* acima — nao precisa de variaveis proprias.)
