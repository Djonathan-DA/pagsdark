# ===========================================================================
# Projeto Dark - variaveis de ambiente
# Copie este arquivo para ".env" e preencha. O .env NUNCA vai pro git.
# ===========================================================================

# Porta do servidor local (3000 costuma estar ocupada por outros apps; usamos 4310)
PORT=4310

# URL base (use a mesma porta acima). Os "redirect URI" do OAuth apontam pra ca.
BASE_URL=http://localhost:4310

# Chave para cifrar os tokens das contas no banco (32+ caracteres aleatorios).
# Gere uma com:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=troque-isto-por-uma-chave-aleatoria-de-32-bytes

# Fuso horario usado nos agendamentos (horarios das campanhas)
TZ=America/Sao_Paulo

# ---------------------------------------------------------------------------
# YouTube (Google Cloud Console -> API "YouTube Data API v3" -> OAuth Client)
# Redirect URI: http://localhost:4310/oauth/youtube/callback
# ---------------------------------------------------------------------------
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Instagram (Meta for Developers -> Facebook Login + Instagram Graph API)
# Conta IG precisa ser Profissional (Business/Creator) ligada a uma Pagina.
# Redirect URI: http://localhost:4310/oauth/instagram/callback
# ---------------------------------------------------------------------------
META_APP_ID=
META_APP_SECRET=

# ---------------------------------------------------------------------------
# TikTok (TikTok for Developers -> Login Kit + Content Posting API)
# Redirect URI: http://localhost:4310/oauth/tiktok/callback
# ---------------------------------------------------------------------------
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Kwai: nao possui API publica de postagem. A plataforma exporta os videos
# para uma pasta e voce posta manualmente. Sem variaveis necessarias.
# ---------------------------------------------------------------------------
